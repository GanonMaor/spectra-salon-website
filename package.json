{
  "version": "2.2.0",
  "name": "spectra-salon-app",
  "description": "Spectra - AI-Powered Salon Management System with Enhanced UGC Landing Page, Neon PostgreSQL and Netlify Functions",
  "scripts": {
    "m5:inventory": "node scripts/catalog-inventory.js",
    "m5:inventory:verbose": "node scripts/catalog-inventory.js --verbose",
    "m5:dry-run": "node scripts/catalog-dry-run.js",
    "product-truth:import": "node scripts/import-product-truth-to-neon.js",
    "dev": "netlify dev",
    "dev:vite": "vite --host --port 3000",
    "process-data": "node scripts/process-market-data.js && node scripts/build-phone-mix-index.js",
    "process:pol-usage": "node scripts/process-pol-customer-usage.js",
    "build:pol-shade-map": "node scripts/build-pol-shade-map.js",
    "build:color-intelligence-dictionary": "node scripts/build-color-intelligence-dictionary.js",
    "build:product-truth-seed": "node scripts/build-product-truth-seed.js",
    "build:catalog-truth": "node scripts/build-catalog-truth.js",
    "build:canonical-product-truth": "node scripts/build-canonical-product-truth.js",
    "validate:usage-import": "node scripts/validate-usage-import.js",
    "check:investor-assets": "node scripts/check-investor-assets.mjs",
    "rebuild-cohorts": "node scripts/rebuild-loreal-cohorts.js",
    "build": "vite build",
    "preview": "vite preview --host",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --config jest.integration.config.js",
    "test:integration:required": "node -e \"if (!process.env.TEST_DATABASE_URL) { console.error('ERROR: TEST_DATABASE_URL is not set. Integration tests require a dedicated test database.'); process.exit(1); }\" && jest --config jest.integration.config.js",
    "test:smoke": "playwright test --project=chromium",
    "test:smoke:headed": "playwright test --project=chromium --headed",
    "build:functions": "tsc --project tsconfig.functions.json",
    "lint": "eslint 'src/**/*.{js,ts,tsx}' 'netlify/functions/**/*.{js,ts}'",
    "setup:dev": "chmod +x scripts/dev-setup.sh && ./scripts/dev-setup.sh",
    "build:beauty-intelligence": "node scripts/build-beauty-intelligence.js",
    "audit:catalog-verification": "node scripts/build-catalog-verification-audit.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@heroicons/react": "^2.2.0",
    "@neondatabase/serverless": "^1.0.1",
    "@radix-ui/react-slot": "^1.2.3",
    "@react-google-maps/api": "^2.20.8",
    "@types/react": "^18.0.27",
    "@types/react-dom": "^18.0.10",
    "axios": "^1.11.0",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^1.2.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.23.6",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.539.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.16.3",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.1",
    "recharts": "^2.15.4",
    "tailwind-merge": "^1.10.0",
    "terser": "^5.43.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/css": "^0.10.0",
    "@eslint/js": "^9.31.0",
    "@eslint/json": "^0.13.0",
    "@eslint/markdown": "^7.0.0",
    "@netlify/functions": "^4.1.12",
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.15",
    "@types/pg": "^8.15.4",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "@vitejs/plugin-react": "^3.1.0",
    "autoprefixer": "^10.4.13",
    "eslint": "^9.31.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.3.0",
    "jest": "^30.0.4",
    "jest-environment-jsdom": "^30.0.4",
    "postcss": "^8.4.21",
    "puppeteer-core": "^25.2.1",
    "rollup-plugin-visualizer": "^6.0.3",
    "tailwindcss": "^3.2.6",
    "ts-jest": "^29.4.0",
    "typescript": "^4.9.3",
    "vite": "^4.1.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-imagemin": "^0.6.1"
  },
  "keywords": [
    "salon",
    "management",
    "ai",
    "react",
    "netlify",
    "neon"
  ],
  "author": "Spectra CI Team",
  "license": "MIT"
}
